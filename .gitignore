# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/

# Type checking
.mypy_cache/
.ruff_cache/

# Alembic (keep migrations, ignore generated artifacts)
# backend/alembic/versions/ is intentionally tracked

# ─── Node / Frontend ──────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/

# Build output
dist/
frontend/dist/

# Vite
*.local
frontend/.vite/

# Testing
frontend/test-results/
frontend/playwright-report/
frontend/blob-report/
frontend/playwright/.cache/
frontend/coverage/

# ─── Environment & secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# ─── Docker ───────────────────────────────────────────────────────────────────
# Keep docker-compose.yml; ignore local overrides
docker-compose.override.yml
docker-compose.local.yml

# ─── IDEs & editors ───────────────────────────────────────────────────────────
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
